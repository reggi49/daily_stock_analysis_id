# Use union merge strategy for changelog
# When multiple concurrent PRs append entries to the end of [Unreleased], Git takes all lines from both sides without producing conflict markers.
# Applies to append-only changelog files.
docs/CHANGELOG.md merge=union

# Documentation image/design assets are binary. Keep GitHub review diffs from
# trying to decode moved binary files as UTF-8.
sources/**/*.ai binary
sources/**/*.gif binary
sources/**/*.ico binary
sources/**/*.jpg binary
sources/**/*.jpeg binary
sources/**/*.png binary
sources/**/*.psd binary
docs/assets/**/*.ai binary
docs/assets/**/*.gif binary
docs/assets/**/*.ico binary
docs/assets/**/*.jpg binary
docs/assets/**/*.jpeg binary
docs/assets/**/*.png binary
docs/assets/**/*.psd binary

# === File types forced to LF (consumed directly by kernel/system interpreters) ===
# Shell scripts (entrypoint.sh, any .sh)
*.sh text eol=lf
*.bash text eol=lf

# Dockerfile (including multi-stage or variants)
Dockerfile text eol=lf
Dockerfile.* text eol=lf

# Makefile
Makefile text eol=lf

# Env files (if sourced directly by shell)
.env text eol=lf

# === New: binary files (Git must not change line endings/encoding) ===
# Certificates, keys, etc. (if any)
*.pem binary
*.crt binary
*.key binary
*.p12 binary