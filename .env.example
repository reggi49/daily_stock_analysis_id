# ===================================
# A-share Watchlist Intelligent Analysis System - Environment Variable Configuration Template
# Copy this file to .env and fill in the real configuration
# ===================================

# Watchlist (comma-separated, supports Shanghai and Shenzhen market codes)
# Shanghai: 600xxx, 601xxx, 603xxx
# Shenzhen: 000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API Keys (supports multiple, comma-separated)
# Get: https://open.anspire.cn/?share_code=QFBC0FYC
# When no higher-priority OpenAI-compatible source is configured, this key can be reused for the Anspire LLM gateway and news search if conditions are met.
# The gateway and models below are example configurations for the current project; availability is subject to the Anspire console and official docs:
# Example gateway: https://open-gateway.anspire.cn/v6
# Example model: Doubao-Seed-2.0-lite (can be overridden with ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro)
# If the gateway differs by region/version, override with ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# Data source configuration
# Tushare Pro Token (optional, get from https://tushare.pro/weborder/#/login?reg=834638)
TUSHARE_TOKEN=
# TickFlow API Key (optional; used for A-share daily K-line, realtime quotes, stock list/name, and market review enhancement; falls back automatically when permissions are insufficient)
# TICKFLOW_API_KEY=
# TICKFLOW_KLINE_ADJUST=none          # none/forward/backward/forward_additive/backward_additive
# TICKFLOW_BATCH_DAILY_ENABLED=true   # When permitted, batch-prefetch daily K-line via TickFlow
# TICKFLOW_BATCH_SIZE=100             # Max number of symbols per TickFlow batch request

# AlphaSift stock selection integration (disabled by default; usually maintained by the Web "Enable Stock Selection" button)
ALPHASIFT_ENABLED=false
# Toggle notes:
# - ALPHASIFT_ENABLED only affects the AlphaSift selection flow, and will not rewrite/migrate/clear existing LITELLM_*/LLM_* config.
# - To disable/roll back, simply set ALPHASIFT_ENABLED to false; existing provider/base_url/custom headers and fallback semantics remain unchanged.
# - Compatibility basis (ops verification): LiteLLM providers and OpenAI-compatible semantics are described in the comments below; the runtime uses the pinned litellm version in requirements.txt by default.
ALPHASIFT_INSTALL_SPEC=git+https://github.com/ZhuLinsen/alphasift.git@9f522747caafd3c0b1ddb7e14d5cf44c8580b6cf
# Compatibility notes:
# - ALPHASIFT_INSTALL_SPEC is only used for the explicit /api/v1/alphasift/install call; it will not automatically overwrite historical .env config.
# - After an upgrade, to use the new pin, clear the variable from the old `.env` and rebuild dependencies/restart the service; or change it to the default above and rebuild the backend.
# - Only changing this field in .env without rolling back `requirements.txt` and `src/config.py` triggers an allow-list rejection (alphasift_install_spec_not_allowed).
# AlphaSift full-market snapshot source priority; when not configured, DSA auto-injects based on whether TUSHARE_TOKEN is set:
# - With TUSHARE_TOKEN: tushare,sina,efinance,akshare_em,em_datacenter
# - Without TUSHARE_TOKEN: sina,efinance,akshare_em,em_datacenter
# SNAPSHOT_SOURCE_PRIORITY=tushare,sina,efinance,akshare_em,em_datacenter
# (To stay consistent with runtime auto-injection, it is recommended to leave this blank and not hardcode a value in this file)
# AlphaSift third-party wrapper data source call timeout guard; avoids efinance/AkShare/Baostock/Tushare/yfinance stalls from slowing down the whole selection run.
# - ALPHASIFT_SOURCE_CALL_TIMEOUT_SEC is the global fallback; set to 0/off/disabled to disable caller-side timeout.
# - SNAPSHOT/Daily specific values take priority over the global value; defaults are 60s / 20s respectively.
# ALPHASIFT_SOURCE_CALL_TIMEOUT_SEC=
# ALPHASIFT_SNAPSHOT_CALL_TIMEOUT_SEC=60
# ALPHASIFT_DAILY_CALL_TIMEOUT_SEC=20
# AlphaSift EastMoney direct-request rate limiting and random jitter; reduces connection jitter during consecutive fallback/hotspot refresh.
# ALPHASIFT_EASTMONEY_MIN_INTERVAL_SEC=1.0
# ALPHASIFT_EASTMONEY_JITTER_SEC=0.3
# The latest AlphaSift supports last-good snapshots, daily history, and industry/concept provider caching; the DSA runtime uses the isolated cache directory under data/alphasift by default.
# To customize, override the paths below; leaving blank will not rewrite existing DSA config.
# ALPHASIFT_DATA_DIR=data/alphasift
# ALPHASIFT_FALLBACK_SNAPSHOT_PATH=data/alphasift/snapshot.last_good.json
# ALPHASIFT_DAILY_HISTORY_CACHE_DIR=data/alphasift/daily_history
# ALPHASIFT_INDUSTRY_PROVIDER_CACHE_DIR=data/alphasift/industry_provider_cache
# AlphaSift industry/concept providers are disabled by default; enabling akshare provides more sector info for theme_heat, industry heat, and LLM context.
# INDUSTRY_PROVIDER=none
# INDUSTRY_PROVIDER_MAX_BOARDS=80
# Single LLM request timeout in seconds; AlphaSift selection reuses DSA's config, and falls back to non-LLM ranking results on timeout.
# LLM_TIMEOUT_SEC=60
# AlphaSift LLM reranking request output cap; only affects AlphaSift selection reranking, default 2048.
# LLM_MAX_TOKENS=2048

# Finnhub (optional, US stock data source, free tier 60 calls/min)
# Get: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage (optional, US stock data source, free tier 25 calls/day)
# Get: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI (optional, fallback for US/HK stock turnover, volume ratio, PE, etc.)
# Get from https://open.longbridge.com/
# OAuth 2.0 (recommended): first run scripts/generate_longbridge_oauth_token.py to generate the local SDK token cache
# client_id prefers LONGBRIDGE_OAUTH_CLIENT_ID; when blank and no Legacy Access Token, falls back to LONGBRIDGE_APP_KEY
# GitHub Actions / Docker can base64-encode the token cache file and fill it into LONGBRIDGE_OAUTH_TOKEN_CACHE_B64
# LONGBRIDGE_OAUTH_CLIENT_ID=
# LONGBRIDGE_OAUTH_TOKEN_CACHE_B64=
# Legacy API Key (for legacy accounts; Access Token is not an OAuth access token)
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# In-process cache seconds for static_info, default 86400; 0=fetch on every request
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# Cooldown seconds after connection-closed exceptions, default 15; during cooldown Longbridge is temporarily skipped to avoid frequent reconnects
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK language matches REPORT_LANGUAGE (zh/en); SDK logs are written to LOG_DIR/longbridge_sdk.log
# Access point (independent of REPORT_LANGUAGE; blank uses the defaults below):
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# Override access point; the SDK internally uses LONGPORT_REGION (without BRIDGE) to auto-select,
# and the code auto-syncs LONGBRIDGE_REGION -> LONGPORT_REGION.
# hk -> *.longbridge.com  |  cn -> *.longbridge.cn
# See also: https://open.longbridge.com/zh-CN/docs/getting-started#环境变量
# Overnight session quotes true/false, default false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K-line push realtime or confirmed, default realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# Whether to print quote packets on connect (consistent with README / full-guide: defaults to disabled when unset, i.e. false)
# Set to 1 / true / yes to enable verbose SDK quote-packet logging (for debugging Longbridge connection)
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# Remote update of the stock autocomplete index (enabled by default; auto-degrades to the local built-in index when GitHub is unreachable)
STOCK_INDEX_REMOTE_UPDATE_ENABLED=true

# ===================================
# AI Model Configuration
# ===================================
# Full docs: docs/LLM_CONFIG_GUIDE.md
#
# 【Quick Start】Fill one API Key and it runs; the system auto-detects the model.
#   Anspire Open (all-in-one model+search) -> set ANSPIRE_API_KEYS
#   Gemini (free quota) -> set GEMINI_API_KEY
#   DeepSeek (cost-effective) -> set DEEPSEEK_API_KEY
#   AIHubmix (aggregator) -> set AIHUBMIX_KEY
#
# 【Advanced】Need multi-model / multi-platform fallback -> configure "multi-channel" below or manage visually in the Web settings page.
# ===================================

# Generation backend: litellm by default; codex_cli / claude_code_cli / opencode_cli are explicit opt-in local CLI backends (experimental/limited).
# OpenCode CLI uses the local OpenCode default model; OPENCODE_CLI_MODEL is only an optional --model override.
# Local CLI Backend is not the same as an offline model; the service behind the CLI may process stock codes, news, holdings context, analysis prompts, and report drafts.
# Docker / CI / remote server do not natively have desktop CLI login state; DSA does not read Claude/OpenCode credential files.
# DSA uses a minimal env allowlist + provider credential denylist to reduce API key / webhook token leakage risk.
# The Web settings page's quick check is read-only config and executable visibility; JSON tests actually issue real generation backend smoke requests.
GENERATION_BACKEND=litellm
# OPENCODE_CLI_MODEL=provider/model
# Backend-level fallback; a blank local .env disables backend-level fallback, and litellm -> litellm resolves to a no-op.
# The default GitHub Actions workflow explicitly uses litellm when this variable is not set; to disable fallback in Actions, set it to the primary backend for a self no-op.
GENERATION_FALLBACK_BACKEND=litellm
# Local CLI backend execution limits; max timeout 3600, max output 33554432 bytes, max concurrency 16 / 4 respectively.
GENERATION_BACKEND_TIMEOUT_SECONDS=300
GENERATION_BACKEND_MAX_OUTPUT_BYTES=1048576
GENERATION_BACKEND_MAX_CONCURRENCY=1
LOCAL_CLI_BACKEND_MAX_CONCURRENCY=1
# Agent Chat backend; the Web settings page only exposes auto/litellm; hand-written local CLI backend returns an unsupported tool-calling diagnostic.
AGENT_GENERATION_BACKEND=auto

# --- API Key (fill one) ---

# Gemini (https://aistudio.google.com)
GEMINI_API_KEY=
# Multi-key load balancing: GEMINI_API_KEYS=key1,key2,key3

# DeepSeek (https://platform.deepseek.com)
# Compatibility default: with only DEEPSEEK_API_KEY set, deepseek-chat is still used, and logs prompt migration to deepseek-v4-flash
# DEEPSEEK_API_KEY=

# AIHubmix aggregator (https://aihubmix.com/?aff=CfMq)
# One key for GPT/Claude/Gemini/GLM/Qwen models, no VPN needed
# AIHUBMIX_KEY=

# Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=

# OpenAI / compatible API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # Third-party API address (relay/proxy), blank uses official

# Ollama local model (no API Key needed, recommended)
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# Or use channel mode:
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# Sampling temperature (0.0-2.0, default 0.7; 0 highest determinism, 2 highest randomness)
# Strict temperature compatibility sources:
# - Moonshot API / model docs: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot official model card (eval default temperature = 1.0): https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI Chat Completions spec: https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI-Compatible spec: https://docs.litellm.ai/docs/providers/openai_compatible
# Current repo runtime dependency constraint: litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0 (explicitly excludes PyPI incident versions, see requirements.txt).
# Therefore kimi-k2.6 auto-switches to 1.0/0.6; GPT-5 / o-series and other default-temperature models omit temperature to avoid API rejection.
# If a compatible platform returns an explicit unsupported-parameter error, the runtime corrects the parameter within the current request and retries once; successful strategy is only cached in-process.
# top_p, presence_penalty, frequency_penalty, seed, if returning "unsupported parameter", also trigger request-level correction and retry (without rewriting LLM_TEMPERATURE).
# Other models and fallback still use your configured LLM_TEMPERATURE.
# The Web settings page / desktop import will not silently clear or rewrite LLM_TEMPERATURE; it only temporarily adapts model parameters right before issuing a request.
# If the main model switches back to a normal model, the originally configured temperature auto-restores; the minimal rollback is to revert this LLM parameter adaptation change.
# LLM_TEMPERATURE=0.7

# LLM usage telemetry message HMAC configuration (optional)
# When blank by default, the system generates .llm_usage_hmac_secret in the data directory, comparable within a local deployment.
# Only explicitly configure the same random key when cross-deployment usage message HMAC comparison is needed; update the version label synchronously on rotation.
# When explicitly configuring, use a high-entropy random value (e.g. openssl rand -hex 32), and do not commit real keys to version control.
# LLM_USAGE_HMAC_SECRET=
# LLM_USAGE_HMAC_KEY_VERSION=local-v1

# Provider prompt cache configuration (optional)
# TELEMETRY only controls provider cache usage / diagnostics logging; it does not control provider implicit cache.
# HINTS controls whether to proactively send verified provider-specific hints like prompt_cache_key, cache_control, user_id; disabled by default.
# DIAGNOSTICS_LEVEL options off/basic/debug; debug only outputs desensitized diagnostics, does not record raw prompt or request body.
# LLM_PROMPT_CACHE_TELEMETRY_ENABLED=true
# LLM_PROMPT_CACHE_HINTS_ENABLED=false
# LLM_PROMPT_CACHE_DIAGNOSTICS_LEVEL=off

# --- Multi-channel configuration (optional, also configurable in the Web settings page) ---
# Each channel independently configures base_url / api_key / models, supporting multi-key polling and automatic fallback.
#
# Example: DeepSeek + Gemini dual channel
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# Example: custom API endpoint (third-party proxy / aggregator / relay)
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# Example: Ollama local model (no API Key needed)
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# Example: Hermes local HTTP generation (Phase 3, only normal analysis/JSON; no Agent tools, Stream, or Vision)
# LLM_CHANNELS=hermes
# LLM_HERMES_PROTOCOL=openai
# LLM_HERMES_BASE_URL=http://127.0.0.1:8642/v1
# LLM_HERMES_API_KEY=sk-local-hermes
# LLM_HERMES_MODELS=hermes-agent
# LITELLM_MODEL=openai/hermes-agent
#
# Common vendor templates (copy any one into .env; full docs in docs/llm-providers.md)
#
# Anspire Open (shared search and LLM Key, OpenAI Compatible)
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6 (example)
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro (example models)
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite (example)
#
# AIHubmix aggregator platform (OpenAI Compatible)
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI official
# LLM_CHANNELS=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek official
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini official (official protocol, Base URL blank)
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude official (official protocol, Base URL blank)
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# Kimi / Moonshot (OpenAI Compatible)
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# Tongyi Qianwen DashScope (OpenAI Compatible)
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# Zhipu GLM (OpenAI Compatible)
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax (OpenAI Compatible)
# Source: official OpenAI API compatible docs https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM routes to the Chat Completions-compatible Base URL via openai/<model>.
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# Xiaomi MiMo (OpenAI Compatible)
# Base URL and model name should follow MiMo's official docs/console.
# LLM_CHANNELS=mimo
# LLM_MIMO_PROTOCOL=openai
# LLM_MIMO_BASE_URL=
# LLM_MIMO_API_KEY=sk-xxx
# LLM_MIMO_MODELS=mimo-xxx
# LITELLM_MODEL=openai/mimo-xxx
# Note: the repo's default daily_analysis workflow does not explicitly pass through LLM_MIMO_*; this example defaults to local .env, Docker, or self-hosted scripts; for Actions usage, complete the workflow mapping synchronously.
#
# Volcengine Ark / Doubao (OpenAI Compatible, adjust endpoint by the actually enabled region)
# Source: Volcengine Ark online inference / Responses API docs https://www.volcengine.com/docs/82379/2121998
# LiteLLM routes to the Chat Completions-compatible Base URL via openai/<model>.
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# SiliconFlow (OpenAI Compatible)
# Source: official model list https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter (OpenAI Compatible)
# Source: official Models API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# Advanced: model routing YAML configuration (optional, see docs/examples/litellm_config.example.yaml)
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# Search Engine Configuration (for fetching stock news)
# ===================================
# Bocha API Keys (Chinese search optimized, supports AI summaries, supports multiple, comma-separated)
# Get: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key (Coding Plan Web Search, supports multiple, comma-separated)
# Get: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys (supports multiple, comma-separated)
TAVILY_API_KEYS=
# SerpAPI Keys (supports multiple, comma-separated)
SERPAPI_API_KEYS=
# Brave Search API Keys (supports multiple, comma-separated)
# Get: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG instance addresses (comma-separated, private deployment has no quota, requires format: json enabled in settings.yml)
# The GitHub Actions daily analysis workflow supports same-name Variables first, Secrets fallback; public addresses can be configured as Variables.
# When blank, public instances are auto-fetched from searx.space by default; set the switch below to false if you do not want to access public instances
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# News Freshness and Analysis Filtering Configuration
# ===================================
# News strategy window tiers: ultra_short(1 day) / short(3 days) / medium(7 days) / long(30 days)
# Actual window = min(strategy window, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# Max news freshness in days; limits search results to recent, avoiding stale info
# NEWS_MAX_AGE_DAYS=3
# Local news/intel pool retention days; only clears the intel_items pool, does not affect historical reports
# NEWS_INTEL_RETENTION_DAYS=30
# Single RSS/Atom source fetch timeout (seconds)
# NEWS_INTEL_FETCH_TIMEOUT_SEC=8
# Max items collected per source per fetch
# NEWS_INTEL_MAX_ITEMS_PER_SOURCE=50
# When enabled, before individual stock analysis, Agent analysis, and market review read the local intel pool, auto-initialize built-in sources and fetch enabled ones;
# disabled by default to avoid unconfirmed external requests and analysis input changes
# Note: the repo's default daily_analysis workflow does not explicitly pass through this variable; for Actions usage, complete the workflow mapping synchronously
# NEWS_INTEL_AUTO_FETCH_ENABLED=false
# NewsNow HTTP API base address -- external dependency configuration
# - Official project and deployment guide: https://github.com/qqhann/newsnow
# - The current default https://newsnow.busiyi.world is a public sample instance with the following risks:
#   * May become unavailable due to official maintenance or rate limiting
#   * No guarantee of stability or data reliability; for demonstration and testing only
# - For production, strongly recommend switching to a self-hosted NewsNow instance for control and stability
# - Before deployment, verify API contract compatibility (see docs/intelligence-sources.md):
#   curl -sS "https://newsnow.busiyi.world/api/s?id=cls-hot" | python -c "import sys, json; data=json.load(sys.stdin); assert isinstance(data.get('items'), list)"
# - This config only controls intel source collection and cleanup behavior, and does not change LLM / provider / base URL / compatibility fallback semantics
# NEWSNOW_BASE_URL=https://newsnow.busiyi.world
# Deviation rate threshold (%) ; deviating from MA5 beyond this suggests not chasing highs; strong trend stocks auto-relax to 1.5x
# BIAS_THRESHOLD=5.0

# ===================================
# Agent Strategy Dialogue Configuration (Web chat page)
# ===================================
# Enable Agent strategy dialogue (default false, internally unified as skill)
# AGENT_MODE=true
# Agent main model (optional): inherits main model when blank; without provider prefix resolves as openai/<model>
# AGENT_LITELLM_MODEL=
# Agent max reasoning steps cap (default 10: each sub-Agent runs by its own preset; above 10 all sub-Agents uniformly adopt this value; below a sub-Agent's default caps it as upper bound)
# AGENT_MAX_STEPS=10
# Default enabled strategies (comma-separated); when not configured, uses the built-in defaults below
#
# Built-in strategy skill list (any combination):
#   bull_trend          -- Bull Trend (MA5>MA10>MA20 alignment + low deviation)
#   ma_golden_cross     -- MA Golden Cross (MA5 crosses above MA10/MA20)
#   volume_breakout     -- Volume Breakout (price breaks recent high + volume expands)
#   hot_theme           -- Hot Theme (policy/industry hotspots, sector diffusion, and stock relevance)
#   event_driven        -- Event Driven (earnings, policy, orders, M&A, and other catalysts)
#   growth_quality      -- Growth Quality (revenue/profit, ROE, cash flow, and growth sustainability)
#   expectation_repricing -- Expectation Repricing (earnings/policy/valuation expectation-gap repair or miss)
#   shrink_pullback     -- Shrink Volume Pullback (pullback to MA + volume contraction, low-buy point)
#   bottom_volume       -- Bottom Volume Surge (low volume marks the bottom, bottom reversal signal)
#   dragon_head         -- Dragon Head (strong leader, trend-continuation chase)
#   one_yang_three_yin  -- One Yang Three Yin (strong reversal pattern after main force washout)
#   box_oscillation     -- Box Oscillation (range high-sell low-buy)
#   chan_theory         -- Chan Theory (Zen channel theory: stroke/segment/hub)
#   wave_theory         -- Elliott Wave Theory (Elliott wave counting)
#   emotion_cycle       -- Sentiment Cycle (market sentiment high/low rotation)
#
# When blank, the system uses the main default strategy skill declared in metadata (built-in default is bull_trend)
# AGENT_SKILLS=
#
# You can also manually specify a set of strategies:
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# Fully enable all built-in strategies (two equivalent forms):
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# Custom strategy directory (optional, place custom YAML strategy files; env var name follows internal skill naming)
# AGENT_SKILL_DIR=./strategies

# Agent architecture mode (default single; multi is multi-Agent orchestration mode)
# AGENT_ARCH=single

# Multi-Agent orchestration mode (only effective when AGENT_ARCH=multi)
# quick: technical analysis -> decision (fastest, ~2 LLM calls)
# standard: technical -> intel -> decision (default)
# full: technical -> intel -> risk -> decision
# specialist: technical -> intel -> risk -> strategy expert evaluation -> decision
# AGENT_ORCHESTRATOR_MODE=standard

# Agent execution timeout budget (seconds, 0 disables; single-agent uses it as the overall loop budget, multi-agent as the collaboration orchestration budget; default 600)
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# Whether the risk-control Agent can veto buy signals (default enabled)
# AGENT_RISK_OVERRIDE=true

# Memory and calibration system (tracks historical accuracy, auto-adjusts confidence)
# AGENT_MEMORY_ENABLED=false

# Auto-weight strategy opinions by backtest performance
# AGENT_SKILL_AUTOWEIGHT=true

# Strategy routing mode (auto=select by market state / manual=use AGENT_SKILLS list)
# AGENT_SKILL_ROUTING=auto

# Stock-query visible dialogue context compression (disabled by default). When enabled, only compresses the user-visible user/assistant history, not the same-round tool/thinking passthrough.
# AGENT_CONTEXT_COMPRESSION_ENABLED=false
# Compression profile: cost=more token-saving / balanced=balanced / long_context_raw_first=prefer retaining more original text
# AGENT_CONTEXT_COMPRESSION_PROFILE=balanced
# History token threshold that triggers compression; blank follows the current profile preset
# AGENT_CONTEXT_COMPRESSION_TRIGGER_TOKENS=
# On compression, the most recent N user turns and their following replies are kept as-is; blank follows the current profile preset
# AGENT_CONTEXT_PROTECTED_TURNS=

# Event alert monitoring (schedule-mode background polling; reuses configured notification channels after triggering)
# Compatibility note: this section only adds alert rule config, and does not modify model name, provider, Base URL, LiteLLM, or LLM config semantics; rollback is just disabling/removing event monitoring config.
# legacy JSON only supports three single-symbol basic rule types; technical indicators, watchlist, holdings/account, and market red-green-light rules should use the Web/API alert center.
# legacy JSON supported rules:
#   price_cross          -- price breakout threshold, direction: above / below, field: price
#   price_change_percent -- change percentage threshold, direction: up / down, field: change_pct (unit: %)
#   volume_spike         -- volume expansion, field: multiplier (multiple of near 20-day average volume)
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]
# ====== DingTalk Bot (DingTalk) ======
# DingTalk group bot Webhook URL
DINGTALK_WEBHOOK_URL=
# DingTalk bot signature secret (string starting with SEC); can be blank if signature is not enabled
DINGTALK_SECRET=
# ===================================
# Notification Channel Configuration (multiple can be configured simultaneously, all pushed)
# ===================================
#
# 【Method 1】WeCom (Enterprise WeChat) Bot
# In WeCom group -> Settings -> Group Bot -> Add -> Copy Webhook address
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# 【Method 2】Feishu (Lark) Bot (choose one of two)
#
# Method 2a -- Group custom bot Webhook
# In Feishu group -> Settings -> Group Bot -> Add Bot -> Custom Bot -> Copy Webhook address
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# If the bot security setting has "signature verification" enabled, fill in the secret synchronously
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# If the bot security setting has "keyword" enabled, fill in the same keyword; the system auto-prepends it to every message
# FEISHU_WEBHOOK_KEYWORD=Stock Daily Report
#
# Method 2b -- Feishu App Bot push
# Create an app on the Feishu Open Platform, enable im:message permission, and publish.
#
# Group chat mode (recommended): add the bot to the target group, get chat_id from group settings
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
#
# Private chat mode: send direct messages to a specified user. The user's open_id is obtained from bot events or the contacts API.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=ou_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_DOMAIN=feishu  # domain: feishu (domestic) / lark (international larksuite.com)
#
# 【Method 3】Telegram Bot (both items must be configured)
# 1. Find @BotFather on Telegram -> /newbot -> Get Bot Token
# 2. Get Chat ID: send a message to @userinfobot or visit https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# 【Method 4】Email push (only 2 configs needed, SMTP auto-detected)
# Supports QQ Mail, 163 Mail, Gmail, etc. that support SMTP auth code / basic auth
# Outlook / Exchange are not supported in the current version if the tenant forces OAuth2
# 1. Get auth code (QQ Mail example): Settings -> Account -> POP3/SMTP Service -> Enable -> Get auth code
# 2. Fill in the two items below:
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # optional, blank sends to yourself
#
# 【Method 4 extension】Stocks grouped to different emails (Issue #268, optional)
# STOCK_LIST determines the actual analysis scope; STOCK_GROUP_N only determines who the email is sent to, recommend always writing it as a subset of STOCK_LIST
# Telegram / WeCom / Webhook and other channels still push by the full STOCK_LIST, and are not split by group
# The repo's default GitHub Actions daily_analysis workflow does not auto-inject any numbered STOCK_GROUP_N / EMAIL_GROUP_N
# So this capability applies to local .env, Docker, or other run environments that explicitly inject these variables
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# 【Method 5】Custom Webhook (supports multiple, comma-separated)
# Applicable to: DingTalk, Discord, Slack, Bark, self-built services, any Webhook supporting POST JSON
# The system auto-detects common services and uses the corresponding format
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # optional, for Webhooks requiring auth (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # optional, global JSON body template, overrides auto payload for Bark/Slack/Discord; recommend $content_json/$title_json
# When hand-writing .env for Docker Compose, write $$content_json/$$title_json; the Web settings page auto-escapes, and runtime still restores to single $
# WEBHOOK_VERIFY_SSL=true   # verify by default; affects webhook-style HTTPS notification requests reading this config. Set false to support self-signed certs. Warning: disabling creates MITM hijack risk, only for trusted internal networks
#
# 【Method 6】Pushover configuration
# Register a Pushover account and create an app Token at https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# 【Method 6 extension】ntfy configuration
# NTFY_URL must include the topic path, e.g. https://ntfy.sh/my-topic or https://self-hosted:port/my-topic
# The system parses the topic and sends Markdown text via the ntfy JSON publish API.
# NTFY_URL=
# NTFY_TOKEN=  # optional, for topics requiring Bearer Token or self-hosted ntfy server
#
# 【Method 6 extension】Gotify configuration
# GOTIFY_URL is the Gotify server base URL, without /message; the system appends /message and sends the token via the X-Gotify-Key Header.
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# 【Method 7】PushPlus configuration (domestic push service, recommended)
# Register a PushPlus account and get Token at https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# Group push: after filling the group code, messages are pushed to all subscribed users of the group (one-to-many)
# PUSHPLUS_TOPIC=
#
# 【Method 8】Discord configuration
# Supports two methods: Webhook (recommended, simple config) and Bot API (higher permission)
#
# Method 1: Discord Webhook (recommended, no Bot account needed)
# In Discord channel Settings -> Integrations -> Webhook -> New Webhook -> Copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
#
# Method 2: Discord Bot API (needs Bot account and channel ID)
# 1. Create Bot: https://discord.com/developers/applications -> New Application -> Bot -> Create Bot
# 2. Get Bot Token: Bot page -> Reset Token
# 3. Get Channel ID: Discord enable Developer Mode -> right-click channel -> Copy ID
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # legacy variable name, recommend switching to DISCORD_MAIN_CHANNEL_ID
# DISCORD_MAX_WORDS=2000 # Discord single content limit is 2000; runtime auto-truncates to <=2000 and splits long reports
# If you want to receive Discord Interaction / Webhook callbacks, you must configure the public key for signature verification
# Get: Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
#
# 【Method 9】Slack configuration
# Supports two methods: Bot API (recommended) and Incoming Webhook
# When both configured, Bot API is preferred to ensure text and images are sent to the same channel.
#
# Method 1: Slack Bot API (recommended, supports image upload)
# 1. Create Slack App: https://api.slack.com/apps -> Create New App
# 2. Add Bot Token Scopes: chat:write, files:write
# 3. Install to workspace and get Bot Token (xoxb-...)
# 4. Get Channel ID: channel details -> copy channel ID at bottom
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# Method 2: Slack Incoming Webhook (simple config, no image upload)
# In the Slack App management page, create an Incoming Webhook -> Copy URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# 【Method 10】ServerChan3 configuration (domestic push service, supports WeChat push)
# Register a ServerChan3 account and get SendKey at https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# 【Method 11】AstrBot configuration
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # optional, for AstrBot Webhook requiring Bearer Token
#
# 【Advanced Configuration】Message length limit (bytes)
# Exceeding the limit auto-splits the send; usually no need to modify
# FEISHU_MAX_BYTES=20000    # Feishu limit ~20KB, default 20000 bytes
# FEISHU_SEND_AS_FILE=false # when true, Feishu sends the report as a file (App Bot mode), default is text message
# WECHAT_MAX_BYTES=4000     # WeCom limit 4096 bytes, default 4000 bytes
#
# 【Markdown to Image】(Issue #455)
# For channels that do not support Markdown, convert the report to an image to improve readability
# Single-stock push + image: requires both MARKDOWN_TO_IMAGE_CHANNELS configured and the image tool installed
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # comma-separated
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # beyond this length, no conversion to avoid oversized images
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(default) | markdown-to-file (better emoji, requires npm i -g markdown-to-file)
# Image tool: wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf), or markdown-to-file
#
# 【Notification Routing Strategy】(Issue #1200 P3)
# Default blank: this type of notification is sent to all configured channels. After filling, only sent to the listed configured channels.
# Allowed values: wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# 【Notification Noise Reduction Mechanism】(Issue #1200 P4)
# All disabled by default; only affects static notification channels, not bot-triggered session receipts.
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # same stable dedup key sent only once within TTL; 0 disables
# NOTIFICATION_COOLDOWN_SECONDS=0       # same cooldown key rate-limited within window; 0 disables
# NOTIFICATION_QUIET_HOURS=             # quiet period, format HH:MM-HH:MM, supports crossing midnight
# NOTIFICATION_TIMEZONE=                # quiet period timezone, e.g. Asia/Shanghai; blank follows TZ/system local timezone
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical; blank keeps current state
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # reserved config; currently no daily digest is sent
#
# 【Realtime Quote Prefetch】(Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # set false to disable, avoid efinance/akshare_em full-market pull; tushare is single-stock interface, prefetch only pulls the first stock

# ===================================
# Single-Stock Push Configuration (optional)
# ===================================
# Single-stock push mode: push immediately after each stock is analyzed, rather than after aggregation
# SINGLE_STOCK_NOTIFY=false
#
# Report type: simple (concise), full (complete), brief (3-5 sentence summary)
# In Docker, if push content is incomplete, set to full
# REPORT_TYPE=simple
# Report output language: zh (Chinese, default) / en (English) / ko (Korean)
# REPORT_LANGUAGE=zh
# Analysis result summary only: when true, only push the summary, without per-stock details
# REPORT_SUMMARY_ONLY=false
# Show the LLM model name used in this analysis at the bottom of the notification report; set false to hide
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / integrity check / history compare)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# Merge individual stock analysis and market review into one push (default false), reducing email count and spam risk
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# Analysis Interval Configuration (optional)
# ===================================
# Delay between individual stock analysis and market analysis (seconds)
# Used to avoid triggering rate limits on AI APIs like Gemini
# ANALYSIS_DELAY=0

# App Key (shared with Webhook mode)
DINGTALK_APP_KEY=xxxx
# App Secret (shared with Webhook mode)
DINGTALK_APP_SECRET=xxxx
# Enable Stream mode
DINGTALK_STREAM_ENABLED=false

# Feishu App configuration (for App Bot active push / Stream Bot / cloud docs; does not directly enable group Webhook push)
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # App Bot active push also needs FEISHU_CHAT_ID; for simple group push prefer FEISHU_WEBHOOK_URL
# App Bot active push target; not needed for Stream Bot or cloud docs
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
# Enable long-connection mode
FEISHU_STREAM_ENABLED=false
# Feishu group bot Webhook security configuration (only used in Webhook push mode)
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=Stock Daily Report

# Database path
DATABASE_PATH=./data/stock_analysis.db
# SQLite write optimization: file DB enables WAL by default, reducing lock contention on bulk writes and concurrent writeback
SQLITE_WAL_ENABLED=true
# SQLite lock wait timeout (milliseconds)
SQLITE_BUSY_TIMEOUT_MS=5000
# Max retry count when SQLite hits database is locked / database table is locked
SQLITE_WRITE_RETRY_MAX=3
# SQLite write retry base backoff time (seconds, exponentially increasing)
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# Analysis history snapshot: set false to not persist the full context_snapshot
# Includes enhanced_context, market_phase_summary, AnalysisContextPack overview, diagnostics, and raw snapshot fields
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# Backtest Configuration (optional)
# ===================================
# Whether to enable backtest (true/false)
BACKTEST_ENABLED=true
# Backtest evaluation window (trading days)
BACKTEST_EVAL_WINDOW_DAYS=10
# Only backtest analysis records from N days ago (avoid incomplete same-day/recent data)
BACKTEST_MIN_AGE_DAYS=14
# Backtest engine version (used to distinguish results when backtest logic upgrades)
BACKTEST_ENGINE_VERSION=v1
# Neutral band threshold (%) , e.g. 2 means -2%~+2% is treated as oscillation
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === Scheduled Task Configuration ===
# Whether to enable scheduled tasks (true/false)
SCHEDULE_ENABLED=false
# Daily execution time (HH:MM format, 24-hour)
SCHEDULE_TIME=18:00
# Multiple execution time list (comma-separated, uses SCHEDULE_TIME when blank)
SCHEDULE_TIMES=
# Whether to run analysis once immediately on schedule-mode startup (true/false)
# If not explicitly set, schedule mode inherits RUN_IMMEDIATELY's runtime override semantics for backward compatibility
SCHEDULE_RUN_IMMEDIATELY=true
# Whether to run analysis once immediately on non-schedule-mode startup (true/false)
RUN_IMMEDIATELY=true
# Whether to enable market review (true/false)
MARKET_REVIEW_ENABLED=true
# Whether to inject market environment summary into individual stock analysis Prompt and enable conservative guardrails (true/false, default on)
DAILY_MARKET_CONTEXT_ENABLED=true
# Market review market region: cn (A-share), hk (HK), us (US), jp (Japan), kr (Korea), both (all markets);
# supports comma subsets (e.g. cn,us,kr); illegal/blank values fall back to cn. cn/hk/us/jp/kr suit users focused only on the corresponding single region
# MARKET_REVIEW_REGION=cn
# Market review index up/down colors: green_up=green up red down (default), red_up=red up green down
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# Proxy Configuration (optional)
# ===================================
# Whether to enable proxy (true/false, default false)
# Only takes effect in local dev environment; GitHub Actions environment skips automatically
USE_PROXY=false
# Proxy server address (default 127.0.0.1)
PROXY_HOST=127.0.0.1
# Proxy server port (default 10809)
PROXY_PORT=10809

# System configuration
# Log directory
LOG_DIR=./logs
# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# LiteLLM internal log level (DEBUG/INFO/WARNING/ERROR/CRITICAL; default WARNING; temporarily set to DEBUG when troubleshooting internal streaming/routing details)
# LITELLM_LOG_LEVEL=WARNING
# Max concurrent threads (recommend keeping low concurrency to avoid bans)
MAX_WORKERS=3
# Whether to enable debug logging
DEBUG=false

# ===================================
# WebUI Configuration (optional)
# ===================================
# Whether to launch WebUI by default (true/false, default false)
WEBUI_ENABLED=false
# WebUI listen address (default 127.0.0.1; set to 0.0.0.0 for external access in Docker/cloud servers, see docs/deploy-webui-cloud.md)
WEBUI_HOST=127.0.0.1
# WebUI listen port (default 8000)
WEBUI_PORT=8000
# Whether to auto-build the frontend before starting the Web service (npm install && npm run build, default true)
WEBUI_AUTO_BUILD=true
# Under a single-layer trusted reverse proxy (e.g. Nginx -> App), trust X-Forwarded-For to get the real IP, taking the rightmost value for login rate limiting; in multi-layer proxy/CDN scenarios the rate-limit key may degrade to the edge proxy IP, requiring extra evaluation; keep false when directly exposed to the public to prevent forgery
# TRUST_X_FORWARDED_FOR=false

# ===================================
# Web Login Authentication (optional)
# ===================================
# Set true to enable password protection; set the initial password on first visit from the web page, modifiable in "System Settings > Change Password"
# If you forget the password, run on the server: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session validity (hours)

# ===========================================
# Image Recognition of Stock Codes (settings page "Add from Image")
# ===========================================
# Single request timeout 60 seconds; image max 5MB
# Requires at least one of GEMINI_API_KEY, ANTHROPIC_API_KEY, or OPENAI_API_KEY configured (Vision-capable model)

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# TICKFLOW_PRIORITY=2      # TickFlow (A-share) - default: 2; optional, requires TICKFLOW_API_KEY configured
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# Realtime Quote Data Source Priority Configuration
# ===========================================
# Used to get realtime data like volume ratio, turnover rate, PE, etc.
# Optional data sources (comma-separated, tried in order):
#   - tencent: Tencent Finance, has volume ratio/turnover/PE/PB, stable single-stock query (recommended first choice)
#   - akshare_sina: Sina Finance, basic quotes, no volume ratio, but very stable
#   - efinance: EastMoney (efinance lib), has volume ratio, full pull easily blocked
#   - akshare_em: EastMoney (akshare lib), most complete data, full pull easily blocked
#   - tickflow: TickFlow, optional; when ranked in the top two priorities, supports batch prefetch by current symbol
#   - tushare: Tushare Pro, requires 2000 points, comprehensive data (recommended for paid users)
#
# Default priority: tencent > akshare_sina > efinance > akshare_em
# If you have a high-point Tushare Pro account, put tushare first:
# REALTIME_SOURCE_PRIORITY=tickflow,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# Whether to enable realtime quotes (after disabling, uses historical close for analysis)
# ENABLE_REALTIME_QUOTE=true

# Intraday realtime technicals: when enabled, computes MA/bull alignment using realtime price (Issue #234); when disabled uses previous close
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# Whether to enable chip distribution (this interface is unstable, recommended to disable in cloud deployment)
# ENABLE_CHIP_DISTRIBUTION=true

# Whether to enable fundamental aggregation (new P0 capability)
# ENABLE_FUNDAMENTAL_PIPELINE=true

# Fundamental aggregation performance and stability parameters (unit: seconds)
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=3.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: Import / Risk / FX Degradation Configuration
# ===========================================
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# EastMoney interface patch: recommended to enable when EastMoney/Efinance/Akshare interfaces frequently fail (RemoteDisconnected, connection closed)
# After enabling, injects an NID token and random User-Agent, reducing the chance of being rate-limited by EastMoney
# ENABLE_EASTMONEY_PATCH=false
