# Ignore Python caches
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Ignore virtual environments
venv/
.venv/
env/
.env
.env.*
!.env.example
.env.local

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo

# Ignore local repos, CI metadata and runtime artifacts
.git/
.github/
.claude/reviews/
data/
logs/
reports/
*.log

# Ignore tests and docs
tests/
test_*.py
*_test.py
docs/
*.md
!README.md

# Ignore frontend/desktop artifacts not involved in Docker image build
apps/dsa-desktop/
node_modules/
dist/
build/
coverage/
apps/dsa-web/node_modules/
apps/dsa-web/dist/
apps/dsa-web/build/
apps/dsa-web/coverage/
